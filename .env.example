# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://greendesk:changeme@db:5432/greendesk

# Password used by docker-compose for the postgres service (required)
POSTGRES_PASSWORD=changeme

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Secret key for signing JWTs (required — use a long random string)
JWT_SECRET=replace-with-a-long-random-secret

# How long access tokens remain valid (optional, default: 7d)
JWT_EXPIRES_IN=7d

# ─── Email / SMTP ──────────────────────────────────────────────────────────────
# SMTP server hostname (optional — leave blank to log emails to console instead)
SMTP_HOST=

# SMTP port (optional, default: 587)
SMTP_PORT=587

# SMTP credentials (optional)
SMTP_USER=
SMTP_PASS=

# Sender address shown in outgoing emails (optional)
EMAIL_FROM=Green Desk <noreply@greendesk.example.com>

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Allowed origin for cross-origin requests (optional — only needed if API is
# accessed directly from a browser on a different origin)
CORS_ORIGIN=

# ─── Server ────────────────────────────────────────────────────────────────────
# Port the API listens on (optional, default: 3001)
PORT=3001

# Node environment (set to "production" for deployments)
NODE_ENV=production

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Secret key from your Stripe dashboard (required for billing)
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — get from "stripe listen" or dashboard endpoint config
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for each paid plan (required for checkout)
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# Public URL of this app — used for Stripe redirect URLs
APP_URL=https://app.greendesk.example.com
